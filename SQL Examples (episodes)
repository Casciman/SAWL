# Good sequence for getting details.

# Basic episode info for 900–906

select episode_id, date, title
from episodes
where cast(substr(episode_id, 2) as integer) between 900 and 906
order by cast(substr(episode_id, 2) as integer);

# Open up traits_json across 900–906

select distinct j.key
from episodes e, json_each(e.traits_json) j
where cast(substr(e.episode_id, 2) as integer) between 900 and 906
order by j.key;

# Open up evaluation_json across 900–906

select distinct j.key
from episodes e, json_each(e.evaluation_json) j
where cast(substr(e.episode_id, 2) as integer) between 900 and 906
order by j.key;

# Open up traits_json across 900–906 with values

select e.episode_id, j.key, j.value
from episodes e, json_each(e.traits_json) j
where cast(substr(e.episode_id, 2) as integer) between 900 and 906
order by cast(substr(e.episode_id, 2) as integer), j.key;

#  Topics are arrays, so we only get values, not keys. But we can still open them up.

select e.episode_id, j.value as topic
from episodes e, json_each(e.topics_json) j
where cast(substr(e.episode_id, 2) as integer) between 900 and 906
order by cast(substr(e.episode_id, 2) as integer), j.value;

