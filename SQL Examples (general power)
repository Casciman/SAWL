  episode_id,
  date,
  title,
  json_array_length(predictions_json) as preds,
  json_array_length(notable_quotes_json) as quotes,
  json_extract(evaluation_json, '$.impact') as impact
from episodes
where json_array_length(predictions_json) > 0
   or json_extract(evaluation_json, '$.impact') >= 8
order by impact desc, preds desc, quotes desc
limit 25;

