Find predictions and immediately see what was actually said around them.

select
  e.episode_id,
  cast(substr(e.episode_id, 2) as integer) as ep_num,
  e.date,
  e.title,
  p.value as prediction,
  group_concat(s.text, ' ') as context
from episodes e
join json_each(e.predictions_json) p
join segments s on s.episode_id = e.episode_id
where s.seg_index between 20 and 80
group by e.episode_id, p.value
order by ep_num
limit 20;

