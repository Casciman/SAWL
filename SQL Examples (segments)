# Position in the episode as a percentage

WITH ep AS (
  SELECT episode_id, MAX(end_s) AS episode_len_s
  FROM segments
  GROUP BY episode_id
)
SELECT
  s.episode_id,
  s.seg_index,
  ROUND(s.start_s, 2) AS start_s,
  ROUND(e.episode_len_s, 2) AS episode_len_s,
  ROUND(100.0 * s.start_s / e.episode_len_s, 1) AS pct_into_episode,
  s.text
FROM segments s
JOIN ep e ON s.episode_id = e.episode_id
WHERE lower(s.text) LIKE '%persuasion%'
   OR lower(s.text) LIKE '%persuade%'
   OR lower(s.text) LIKE '%persuasive%'
ORDER BY s.episode_id, s.start_s
